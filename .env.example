# Resend (https://resend.com) — wymagane do wysyłki z formularza
RESEND_API_KEY=re_xxxxxxxx

# Nadawca: po weryfikacji domeny rweb.pl w Resend ustaw np.:
# RESEND_FROM=rweb.pl <kontakt@rweb.pl>
# Do testów możesz zostawić domyślny adres Resend (ograniczenia w panelu Resend).
RESEND_FROM=

# Odbiorca zgłoszeń z formularza (domyślnie w kodzie: kontakt@rweb.com)
CONTACT_FORM_TO=kontakt@rweb.com
